# ============================================
# Backend Configuration Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================

# DATABASE_URL - SQLite configuration for local development
# Format: sqlite+aiosqlite:///./database_file.db
# For production, use PostgreSQL format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=sqlite+aiosqlite:///./mindscan_ai.db

# JWT_SECRET_KEY - REQUIRED security credential for token signing
# CRITICAL: This MUST be a strong, random string for security
# Generate a secure 32-byte random key using:
#   - Linux/macOS: openssl rand -hex 32
#   - Python: python -c "import secrets; print(secrets.token_hex(32))"
#   - Or use: https://www.random.org/strings/?num=1&len=64&digits=on&upperalpha=on&loweralpha=on&format=html
# DO NOT use simple strings like "test", "secret", or "123"
# DO NOT commit this to git - use a secure password manager or CI/CD secrets
JWT_SECRET_KEY=your_super_secret_random_key_here_use_openssl_rand_hex_32
